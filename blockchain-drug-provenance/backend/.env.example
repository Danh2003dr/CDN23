# Database Configuration
MONGODB_URI=mongodb://localhost:27017/drug_provenance
MONGODB_TEST_URI=mongodb://localhost:27017/drug_provenance_test

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRE=30d

# Server Configuration  
PORT=5000
NODE_ENV=development

# Blockchain Configuration
BLOCKCHAIN_PROVIDER_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=
ADMIN_PRIVATE_KEY=

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5000000

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# QR Code Configuration
QR_CODE_BASE_URL=https://your-domain.com/verify