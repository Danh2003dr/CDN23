# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cdn_management
DB_USER=root
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h

# Real Data Collection Configuration
USE_REAL_DATA=false
COLLECTION_INTERVAL=30000

# Prometheus Configuration (for real data)
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_ENABLED=false

# SNMP Configuration (for real data)
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TIMEOUT=5000

# Cloudflare Configuration (for real data)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-zone-id

# AWS Configuration (for real data)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1

# Azure Configuration (for real data)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Google Cloud Configuration (for real data)
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_KEY_FILE=path/to/service-account-key.json

# Monitoring Tools Configuration
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your-grafana-api-key

# Alert Configuration
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85
ALERT_DISK_THRESHOLD=90
ALERT_RESPONSE_TIME_THRESHOLD=100
ALERT_ERROR_RATE_THRESHOLD=5
ALERT_CACHE_HIT_RATE_THRESHOLD=70

# Client Configuration
CLIENT_URL=http://localhost:3000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5 